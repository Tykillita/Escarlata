{
  "name": "escarlata",
  "version": "0.1.0",
  "description": "Offline-first desktop assistant for Windows.",
  "author": "Escarlata",
  "main": "out/main/index.js",
  "type": "module",
  "workspaces": [
    "ui",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx src/cli/repl.ts",
    "voice": "tsx src/cli/voice-repl.ts --voice",
    "desktop:dev": "electron-vite dev --config apps/desktop/electron.vite.config.ts",
    "desktop:check": "tsc --noEmit -p apps/desktop/tsconfig.json",
    "desktop:build": "electron-vite build --config apps/desktop/electron.vite.config.ts && electron-builder --config apps/desktop/electron-builder.yml",
    "build": "npm run build -w @escarlata/protocol && tsc && npm run desktop:build",
    "start": "node dist/cli/repl.js",
    "whisper": "tools\\whisper\\Release\\whisper-server.exe -m tools\\whisper\\ggml-small.bin --host 127.0.0.1 --port 8080 -l es",
    "test:tier1": "tsx src/tests/tier1-2-basic.ts",
    "test:tier2": "tsx src/tests/tier2-tools.ts",
    "test:tier2-errors": "tsx src/tests/tier2-errors.ts",
    "test:tier4": "tsx src/tests/tier4-memory.ts",
    "test:tier5": "tsx src/tests/tier5-heartbeat.ts",
    "test:tier6": "tsx src/tests/tier6-safety.ts",
    "test:auth": "tsx src/tests/provider-auth.ts",
    "test:prompts": "tsx src/tests/prompts.ts",
    "test:codex-usage": "tsx src/tests/codex-local-usage.ts",
    "test:usage-stats": "tsx src/tests/usage-stats.ts",
    "test:local-models": "tsx src/tests/local-model-scan.ts",
    "test:vitals": "tsx src/tests/usage-vitals.ts",
    "test:all": "npm run test:tier1 && npm run test:tier2 && npm run test:tier2-errors && npm run test:tier4 && npm run test:tier5 && npm run test:tier6 && npm run test:auth && npm run test:prompts && npm run test:codex-usage && npm run test:usage-stats && npm run test:vitals",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@anthropic-ai/sdk": "^0.109.1",
    "@openai/codex": "^0.144.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "firebase-admin": "^14.1.0",
    "openai": "^6.46.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  }
}
